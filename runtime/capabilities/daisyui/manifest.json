{
  "displayName": "daisyUI",
  "description": "Tailwind CSS component library with themeable semantic class-based components for rapid UI development.",
  "domain": "runtime",
  "inputSchema": "shared/schemas/daisyui-callable-input.schema.json",
  "outputSchema": "shared/schemas/daisyui-callable-output.schema.json",
  "verification": "placeholder",
  "examples": [
    {
      "name": "List available components",
      "input": {
        "tool": "list-components"
      },
      "output": {
        "ok": true,
        "tool": "list-components",
        "data": {
          "components": []
        }
      },
      "match": {
        "invariantFields": ["ok", "tool"]
      }
    }
  ]
}
