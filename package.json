{
  "name": "@directive/kernel",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.32.1",
  "type": "module",
  "scripts": {
    "ui:install": "pnpm install",
    "ui:build": "pnpm --filter @directive/kernel-ui build",
    "ui:dev": "node --experimental-strip-types ./scripts/run-ui-dev.ts",
    "ui:start": "node --experimental-strip-types ./scripts/start-ui.ts",
    "frontend:install": "pnpm install",
    "frontend:build": "pnpm --filter @directive/kernel-ui build",
    "check:hardening": "node --experimental-strip-types ./scripts/check-system-hardening.ts",
    "dev": "node --experimental-strip-types ./scripts/run-ui-dev.ts",
    "start": "pnpm --filter @directive/kernel-ui build && node --experimental-strip-types ./scripts/start-ui.ts",
    "standalone:cli": "node --experimental-strip-types ./hosts/standalone-host/cli.ts",
    "web:serve": "node --experimental-strip-types ./hosts/web-host/cli.ts serve --directive-root ."
  },
  "exports": {
    ".": "./index.ts",
    "./engine": "./engine/index.ts",
    "./engine/cases": "./engine/cases/index.ts",
    "./engine/coordination": "./engine/coordination/index.ts",
    "./engine/execution": "./engine/execution/index.ts",
    "./integration-kit": "./hosts/integration-kit/index.ts",
    "./integration-kit/cli": "./hosts/integration-kit/cli/host-integration-kit-cli.ts",
    "./integration-kit/starter": "./hosts/integration-kit/starter/index.ts",
    "./standalone-host": "./hosts/standalone-host/index.ts",
    "./standalone-host/bootstrap": "./hosts/standalone-host/bootstrap.ts",
    "./standalone-host/cli": "./hosts/standalone-host/cli.ts",
    "./standalone-host/config": "./hosts/standalone-host/config.ts",
    "./standalone-host/persistence": "./hosts/standalone-host/persistence.ts",
    "./standalone-host/server": "./hosts/standalone-host/server.ts",
    "./ui": "./hosts/web-host/index.ts",
    "./ui/cli": "./hosts/web-host/cli.ts",
    "./ui/server": "./hosts/web-host/server.ts",
    "./frontend": "./hosts/web-host/index.ts",
    "./frontend/cli": "./hosts/web-host/cli.ts",
    "./frontend/server": "./hosts/web-host/server.ts",
    "./architecture": "./architecture/lib/index.ts",
    "./architecture/control": "./architecture/lib/control/index.ts",
    "./architecture/adoption": "./architecture/lib/adoption/index.ts",
    "./architecture/materialization": "./architecture/lib/materialization/index.ts",
    "./architecture/experiments": "./architecture/lib/experiments/index.ts",
    "./discovery": "./discovery/lib/index.ts",
    "./discovery/gaps": "./discovery/lib/gaps/index.ts",
    "./discovery/front-door": "./discovery/lib/front-door/index.ts",
    "./discovery/intake": "./discovery/lib/intake/index.ts",
    "./discovery/routing": "./discovery/lib/routing/index.ts",
    "./discovery/records": "./discovery/lib/records/index.ts",
    "./discovery/importers": "./discovery/importers/index.ts",
    "./runtime": "./runtime/lib/index.ts",
    "./runtime/openers": "./runtime/lib/openers/index.ts",
    "./runtime/projections": "./runtime/lib/projections/index.ts",
    "./runtime/runners": "./runtime/lib/runners/index.ts",
    "./runtime/sequences": "./runtime/lib/sequences/index.ts",
    "./runtime/writers": "./runtime/lib/writers/index.ts",
    "./runtime/host": "./runtime/lib/host/index.ts",
    "./runtime/control": "./runtime/lib/control/index.ts",
    "./engine/state": "./engine/state/index.ts",
    "./engine/mission": "./engine/mission/index.ts",
    "./engine/routing": "./engine/routing/index.ts",
    "./engine/planning": "./engine/planning/index.ts",
    "./shared/directive-goal": "./shared/lib/directive-goal.ts",
    "./runtime/core/runtime-core-contract": "./runtime/core/runtime-core-contract.ts"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0"
  }
}
