{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "shared/schemas/daisyui-callable-output.schema.json",
  "title": "daisyUI Callable Output",
  "description": "Output from daisyUI Tailwind CSS component library operations.",
  "type": "object",
  "required": ["ok", "tool", "data"],
  "properties": {
    "ok": {
      "type": "boolean",
      "description": "Whether the operation succeeded"
    },
    "tool": {
      "type": "string",
      "description": "The daisyUI tool that was invoked"
    },
    "data": {
      "type": "object",
      "description": "Tool-specific response data"
    }
  },
  "additionalProperties": false
}
