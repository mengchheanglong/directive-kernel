{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "shared/schemas/runtime-capabilities.response.schema.json",
  "title": "Runtime Capabilities Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "capabilities"
  ],
  "properties": {
    "$schema": {
      "const": "/api/schemas/runtime-capabilities.response.schema.json"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "displayName",
          "description",
          "modulePath",
          "verification",
          "contract",
          "entryClass",
          "projectionReady"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "displayName": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "modulePath": {
            "type": "string",
            "minLength": 1
          },
          "verification": {
            "type": "string",
            "enum": [
              "verified",
              "claimed",
              "placeholder",
              "runs_unverified_contract"
            ]
          },
          "contract": {
            "type": "string",
            "enum": [
              "complete",
              "partial",
              "missing"
            ]
          },
          "entryClass": {
            "type": "string",
            "enum": [
              "verified_capability",
              "candidate",
              "placeholder",
              "note_only",
              "rejected",
              "architecture_experiment"
            ],
            "description": "Jarvis capability kernel: the classification of this registry entry."
          },
          "projectionKind": {
            "type": "string",
            "enum": [
              "mcp_tool",
              "hermes_skill",
              "cli_wrapper",
              "cron_job",
              "handoff_prompt",
              "obsidian_note"
            ],
            "description": "The Hermes projection mechanism, if present."
          },
          "whenToUse": {
            "type": "string",
            "description": "When Hermes should use this capability."
          },
          "failureModes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Known failure modes."
          },
          "projectionReady": {
            "type": "boolean",
            "description": "Whether this capability is ready for Hermes projection (verified + complete contract + valid projection metadata)."
          },
          "notUsableReason": {
            "type": "string",
            "description": "If not projectionReady, the reason why."
          }
        }
      }
    }
  }
}
