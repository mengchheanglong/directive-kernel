{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "shared/schemas/mission-evolution-history.response.schema.json",
  "title": "Mission Evolution History Response",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": true,
    "required": [
      "evolutionId",
      "version",
      "status",
      "createdAt",
      "operatorRationale",
      "missionSnapshot",
      "appliedDelta",
      "trigger",
      "cascade"
    ],
    "properties": {
      "evolutionId": {
        "type": "string",
        "minLength": 1
      },
      "version": {
        "type": "number"
      },
      "status": {
        "type": "string",
        "minLength": 1
      },
      "createdAt": {
        "type": "string",
        "minLength": 1
      },
      "operatorRationale": {
        "type": "string"
      },
      "missionSnapshot": {
        "type": "object",
        "additionalProperties": true
      },
      "appliedDelta": {
        "type": "object",
        "additionalProperties": true
      },
      "trigger": {
        "type": "object",
        "additionalProperties": true
      },
      "cascade": {
        "type": "object",
        "additionalProperties": true
      }
    }
  }
}
