{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "shared/schemas/literature-access-callable-output.schema.json",
  "title": "Literature Access Callable Output",
  "description": "Output from accessing academic and technical literature through the Scientify research bundle.",
  "type": "object",
  "required": ["ok", "tool", "status", "result", "metadata"],
  "properties": {
    "ok": {
      "type": "boolean",
      "description": "Whether the operation succeeded"
    },
    "tool": {
      "type": "string",
      "enum": ["arxiv-search", "arxiv-download", "openalex-search", "unpaywall-download"],
      "description": "The literature access tool that was invoked"
    },
    "status": {
      "type": "string",
      "enum": ["success", "error", "timeout", "disabled", "validation_error"],
      "description": "Status of the operation"
    },
    "result": {
      "description": "Tool-specific result data",
      "oneOf": [
        { "type": "object" },
        { "type": "array" },
        { "type": "string" },
        { "type": "number" },
        { "type": "boolean" },
        { "type": "null" }
      ]
    },
    "metadata": {
      "type": "object",
      "required": ["startedAt", "completedAt", "durationMs", "timeoutMs", "capabilityId"],
      "properties": {
        "startedAt": {
          "type": "string",
          "format": "date-time"
        },
        "completedAt": {
          "type": "string",
          "format": "date-time"
        },
        "durationMs": {
          "type": "number",
          "minimum": 0
        },
        "timeoutMs": {
          "type": "number",
          "minimum": 1
        },
        "capabilityId": {
          "type": "string",
          "const": "dw-source-scientify-research-workflow-plugin-2026-03-27"
        }
      },
      "additionalProperties": false,
      "description": "Runtime callable execution metadata"
    }
  },
  "additionalProperties": false
}
