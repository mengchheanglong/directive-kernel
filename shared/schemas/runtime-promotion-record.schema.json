{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "directive-workspace/schemas/runtime-promotion-record",
  "title": "Runtime Promotion Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "candidate_id",
    "candidate_name",
    "promotion_date",
    "target_host",
    "promotion_decision"
  ],
  "properties": {
    "candidate_id": { "type": "string", "minLength": 1 },
    "candidate_name": { "type": "string", "minLength": 1 },
    "promotion_date": { "type": "string", "format": "date" },
    "linked_runtime_record": { "type": "string" },
    "target_host": { "type": "string", "minLength": 1 },
    "target_runtime_surface": { "type": "string" },
    "integration_mode": { "type": "string" },
    "source_intent_artifact": { "type": "string" },
    "compile_contract_artifact": { "type": "string" },
    "runtime_permissions_profile": { "type": "string" },
    "safe_output_scope": { "type": "string" },
    "sanitize_policy": { "type": "string" },
    "proposed_runtime_status": { "type": "string" },
    "proof_path": { "type": "string" },
    "quality_gate_profile": { "type": "string" },
    "promotion_profile_family": { "type": "string" },
    "proof_shape": { "type": "string" },
    "primary_host_checker": { "type": "string" },
    "full_text_coverage_threshold": { "type": "string" },
    "evidence_binding_threshold": { "type": "string" },
    "citation_error_threshold": { "type": "string" },
    "observed_full_text_coverage": { "type": "string" },
    "observed_evidence_binding": { "type": "string" },
    "observed_citation_error_rate": { "type": "string" },
    "quality_gate_result": { "type": "string" },
    "validation_state": { "type": "string" },
    "quality_gate_fail_reasons": { "type": "array", "items": { "type": "string" } },
    "required_gates": { "type": "array", "items": { "type": "string" } },
    "validation_result": { "type": "string" },
    "rollback_plan": { "type": "string" },
    "owner": { "type": "string" },
    "promotion_decision": { "type": "string", "minLength": 1 }
  }
}
