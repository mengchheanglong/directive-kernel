{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "shared/schemas/code-normalizer-callable-input.schema.json",
  "title": "Code Normalizer Callable Input",
  "description": "Input for normalizing source code artifacts into a standardized representation for downstream processing.",
  "type": "object",
  "required": ["code"],
  "properties": {
    "code": {
      "type": "string",
      "description": "Source code to normalize"
    },
    "filename": {
      "type": "string",
      "description": "Optional filename hint for language detection"
    },
    "transforms": {
      "type": "object",
      "description": "Optional transform configuration overrides",
      "properties": {
        "collapseBlankLines": {
          "type": "boolean",
          "description": "Collapse consecutive blank lines into one"
        },
        "normalizeTrailingWhitespace": {
          "type": "boolean",
          "description": "Strip trailing whitespace from lines"
        },
        "normalizeLineEndings": {
          "type": "boolean",
          "description": "Normalize line endings to LF"
        }
      }
    }
  },
  "additionalProperties": false
}
