{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "directive-workspace/schemas/runtime-transformation-record",
  "title": "Runtime Transformation Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "candidate_id",
    "candidate_name",
    "record_date",
    "transformation_type",
    "proposed_change",
    "evaluator_type",
    "decision_state"
  ],
  "properties": {
    "candidate_id": { "type": "string", "minLength": 1 },
    "candidate_name": { "type": "string", "minLength": 1 },
    "record_date": { "type": "string", "format": "date" },
    "transformation_type": { "type": "string", "minLength": 1 },
    "discovery_intake_path": { "type": "string" },
    "component": { "type": "string" },
    "current_implementation": { "type": "string" },
    "baseline_metric": { "type": "string" },
    "baseline_value": { "type": "string" },
    "baseline_measurement_method": { "type": "string" },
    "proposed_change": { "type": "string", "minLength": 1 },
    "preservation_claim": { "type": "string" },
    "expected_improvement_metric": { "type": "string" },
    "expected_target_value": { "type": "string" },
    "expected_measurement_method": { "type": "string" },
    "evaluator_type": { "type": "string", "minLength": 1 },
    "evaluator_command": { "type": "string" },
    "comparison_mode": { "type": "string" },
    "baseline_artifact_path": { "type": "string" },
    "result_artifact_path": { "type": "string" },
    "correctness_preserved": { "type": "string" },
    "metric_improvement_measured": { "type": "string" },
    "rollback_path": { "type": "string" },
    "rollback_tested": { "type": "string" },
    "decision_state": { "type": "string", "minLength": 1 },
    "mission_alignment": { "type": "string" },
    "capability_gap_id": { "type": "string" }
  }
}
