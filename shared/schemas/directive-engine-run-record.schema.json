{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://directive-workspace.dev/schemas/directive-engine-run-record.schema.json",
  "title": "Directive Engine Run Record",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "$schema",
    "schemaVersion",
    "recordKind",
    "runId",
    "receivedAt",
    "source",
    "mission",
    "openGaps",
    "selectedLane",
    "candidate",
    "analysis",
    "routingAssessment",
    "extractionPlan",
    "adaptationPlan",
    "improvementPlan",
    "proofPlan",
    "priorPlanContext",
    "decision",
    "integrationProposal",
    "reportPlan",
    "events"
  ],
  "properties": {
    "$schema": {
      "const": "shared/schemas/directive-engine-run-record.schema.json"
    },
    "schemaVersion": {
      "const": 6
    },
    "recordKind": {
      "const": "directive_engine_run_record"
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "receivedAt": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "required": [
        "sourceType",
        "sourceRef",
        "title"
      ],
      "properties": {
        "sourceType": { "type": "string", "minLength": 1 },
        "sourceRef": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 }
      }
    },
    "mission": {
      "type": "object",
      "required": [
        "currentObjective",
        "usefulnessSignals",
        "capabilityLanes",
        "constraints",
        "successSignal",
        "adoptionTarget",
        "activeMissionMarkdown"
      ],
      "properties": {
        "currentObjective": { "type": "string", "minLength": 1 },
        "usefulnessSignals": { "type": "array", "items": { "type": "string" } },
        "capabilityLanes": { "type": "array", "items": { "type": "string" } },
        "constraints": { "type": "array", "items": { "type": "string" } },
        "successSignal": { "type": ["string", "null"] },
        "adoptionTarget": { "type": ["string", "null"] },
        "activeMissionMarkdown": { "type": "string" }
      }
    },
    "openGaps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "gapId",
          "description",
          "priority",
          "relatedMissionObjective",
          "currentState",
          "desiredState",
          "detectedAt"
        ],
        "properties": {
          "gapId": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "priority": { "enum": ["high", "medium", "low"] },
          "relatedMissionObjective": { "type": "string", "minLength": 1 },
          "currentState": { "type": "string", "minLength": 1 },
          "desiredState": { "type": "string", "minLength": 1 },
          "detectedAt": { "type": "string", "minLength": 1 }
        }
      }
    },
    "selectedLane": {
      "type": "object",
      "required": [
        "laneId",
        "label",
        "hostDependence",
        "valuableWithoutHostRuntime"
      ],
      "properties": {
        "laneId": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "hostDependence": { "type": "string", "minLength": 1 },
        "valuableWithoutHostRuntime": { "type": "boolean" }
      }
    },
    "candidate": {
      "type": "object",
      "required": [
        "candidateId",
        "candidateName",
        "recommendedLaneId",
        "recommendedRecordShape",
        "usefulnessLevel",
        "missionPriorityScore",
        "confidence",
        "matchedGapId",
        "matchedGapRank",
        "requiresHumanReview",
        "rationale"
      ],
      "properties": {
        "candidateId": { "type": "string", "minLength": 1 },
        "candidateName": { "type": "string", "minLength": 1 },
        "recommendedLaneId": { "type": "string", "minLength": 1 },
        "recommendedRecordShape": { "type": "string", "minLength": 1 },
        "usefulnessLevel": { "enum": ["direct", "structural", "meta", "hybrid"] },
        "missionPriorityScore": { "type": "number" },
        "confidence": { "enum": ["high", "medium", "low"] },
        "matchedGapId": { "type": ["string", "null"] },
        "matchedGapRank": { "type": ["integer", "null"] },
        "requiresHumanReview": { "type": "boolean" },
        "rationale": { "type": "array", "items": { "type": "string" } }
      }
    },
    "analysis": {
      "type": "object",
      "required": [
        "missionFitSummary",
        "primaryAdoptionQuestion",
        "matchedCapabilityGapId",
        "usefulnessRationale",
        "rationale"
      ],
      "properties": {
        "missionFitSummary": { "type": "string", "minLength": 1 },
        "primaryAdoptionQuestion": { "type": "string", "minLength": 1 },
        "matchedCapabilityGapId": { "type": ["string", "null"] },
        "usefulnessRationale": { "type": "string", "minLength": 1 },
        "rationale": { "type": "array", "items": { "type": "string" } }
      }
    },
    "routingAssessment": {
      "type": "object",
        "required": [
          "recommendedLaneId",
          "recommendedRecordShape",
          "missionPriorityScore",
          "confidence",
          "matchedGapId",
          "matchedGapRank",
          "routeConflict",
          "needsHumanReview",
          "missionSpecificityWarning",
          "missionHealth",
          "goalCopilot",
          "confidenceRecovery",
          "followUpQuestions",
          "gapRadar",
          "earnedAutonomy",
          "sourceMemory",
          "sourceSimilarity",
          "narrativeContext",
          "laneProportions",
          "secondaryLanes",
          "ambiguitySummary",
          "reviewGuidance",
          "scoreBreakdown",
          "explanationBreakdown",
          "rationale"
        ],
      "properties": {
        "recommendedLaneId": { "type": "string", "minLength": 1 },
        "recommendedRecordShape": { "type": "string", "minLength": 1 },
        "missionPriorityScore": { "type": "number" },
        "confidence": { "enum": ["high", "medium", "low"] },
        "matchedGapId": { "type": ["string", "null"] },
        "matchedGapRank": { "type": ["integer", "null"] },
        "routeConflict": { "type": "boolean" },
        "needsHumanReview": { "type": "boolean" },
        "missionSpecificityWarning": { "type": ["string", "null"] },
        "missionHealth": {
          "type": ["object", "null"],
          "required": [
            "overallScore",
            "healthGrade",
            "objectiveSpecificityScore",
            "usefulnessSignalQualityScore",
            "constraintQualityScore",
            "lanePriorityClarityScore",
            "overmatchRiskScore",
            "stalenessRiskScore",
            "warnings",
            "tensionSignals",
            "rationale",
            "suggestedObjectiveRewrite",
            "suggestedConstraintAdditions"
          ],
          "properties": {
            "overallScore": { "type": "number" },
            "healthGrade": { "enum": ["A", "B", "C", "D", "F"] },
            "objectiveSpecificityScore": { "type": "number" },
            "usefulnessSignalQualityScore": { "type": "number" },
            "constraintQualityScore": { "type": "number" },
            "lanePriorityClarityScore": { "type": "number" },
            "overmatchRiskScore": { "type": "number" },
            "stalenessRiskScore": { "type": "number" },
            "warnings": { "type": "array", "items": { "type": "string" } },
            "tensionSignals": { "type": "array", "items": { "type": "string" } },
            "rationale": { "type": "array", "items": { "type": "string" } },
            "suggestedObjectiveRewrite": { "type": ["string", "null"] },
            "suggestedConstraintAdditions": { "type": "array", "items": { "type": "string" } }
          }
        },
        "ambiguitySummary": {
          "type": "object",
          "required": [
            "topLaneId",
            "runnerUpLaneId",
            "scoreDelta",
            "conflictingSignalFamilies",
            "conflictingLaneIds"
          ],
          "properties": {
            "topLaneId": { "type": "string", "minLength": 1 },
            "runnerUpLaneId": { "type": ["string", "null"] },
            "scoreDelta": { "type": "number" },
            "conflictingSignalFamilies": { "type": "array", "items": { "type": "string" } },
            "conflictingLaneIds": { "type": "array", "items": { "type": "string" } }
          }
        },
        "reviewGuidance": {
          "type": ["object", "null"],
          "required": [
            "guidanceKind",
            "summary",
            "operatorAction",
            "requiredChecks",
            "stopLine"
          ],
          "properties": {
            "guidanceKind": { "type": "string", "minLength": 1 },
            "summary": { "type": "string", "minLength": 1 },
            "operatorAction": { "type": "string", "minLength": 1 },
            "requiredChecks": { "type": "array", "items": { "type": "string" } },
            "stopLine": { "type": "string", "minLength": 1 }
          }
        },
        "goalCopilot": {
          "type": "object",
          "required": [
            "overallScore",
            "objectiveSpecificityScore",
            "usefulnessSignalQualityScore",
            "constraintQualityScore",
            "laneClarityScore",
            "warnings",
            "rationale",
            "suggestedObjective",
            "suggestedConstraints",
            "suggestedUsefulnessSignals",
            "suggestedCapabilityLanes"
          ],
          "properties": {
            "overallScore": { "type": "number" },
            "objectiveSpecificityScore": { "type": "number" },
            "usefulnessSignalQualityScore": { "type": "number" },
            "constraintQualityScore": { "type": "number" },
            "laneClarityScore": { "type": "number" },
            "warnings": { "type": "array", "items": { "type": "string" } },
            "rationale": { "type": "array", "items": { "type": "string" } },
            "suggestedObjective": { "type": ["string", "null"] },
            "suggestedConstraints": { "type": "array", "items": { "type": "string" } },
            "suggestedUsefulnessSignals": { "type": "array", "items": { "type": "string" } },
            "suggestedCapabilityLanes": { "type": "array", "items": { "type": "string" } }
          }
        },
        "confidenceRecovery": {
          "type": ["object", "null"],
          "required": [
            "summary",
            "confidenceLift",
            "requestedInputs"
          ],
          "properties": {
            "summary": { "type": "string", "minLength": 1 },
            "confidenceLift": { "type": "string", "minLength": 1 },
            "requestedInputs": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["field", "question", "whyItMatters", "exampleAnswer"],
                "properties": {
                  "field": { "type": "string", "minLength": 1 },
                  "question": { "type": "string", "minLength": 1 },
                  "whyItMatters": { "type": "string", "minLength": 1 },
                  "exampleAnswer": { "type": ["string", "null"] }
                }
              }
            }
          }
        },
        "followUpQuestions": {
          "type": ["object", "null"],
          "required": [
            "summary",
            "questions"
          ],
          "properties": {
            "summary": { "type": "string", "minLength": 1 },
            "questions": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["field", "question", "whyItMatters", "exampleAnswer", "predictedEffect"],
                "properties": {
                  "field": { "type": "string", "minLength": 1 },
                  "question": { "type": "string", "minLength": 1 },
                  "whyItMatters": { "type": "string", "minLength": 1 },
                  "exampleAnswer": { "type": ["string", "null"] },
                  "predictedEffect": { "type": "string", "minLength": 1 }
                }
              }
            }
          }
        },
        "gapRadar": {
          "type": ["object", "null"],
          "required": ["summary", "suggestions"],
          "properties": {
            "summary": { "type": "string", "minLength": 1 },
            "suggestions": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "radarId",
                  "targetLaneId",
                  "confidence",
                  "evidenceCount",
                  "summary",
                  "recommendedChange",
                  "signalTokens",
                  "relatedOpenGapId",
                  "suggestedPriority"
                ],
                "properties": {
                  "radarId": { "type": "string", "minLength": 1 },
                  "targetLaneId": { "type": "string", "minLength": 1 },
                  "confidence": { "enum": ["low", "medium", "high"] },
                  "evidenceCount": { "type": "integer" },
                  "summary": { "type": "string", "minLength": 1 },
                  "recommendedChange": { "type": "string", "minLength": 1 },
                  "signalTokens": { "type": "array", "items": { "type": "string" } },
                  "relatedOpenGapId": { "type": ["string", "null"] },
                  "suggestedPriority": { "enum": ["low", "medium", "high"] }
                }
              }
            }
          }
        },
        "earnedAutonomy": {
          "type": "object",
          "required": [
            "routeClass",
            "overallScore",
            "evidenceCount",
            "operatorAgreementRate",
            "reviewClearRate",
            "reversalCount",
            "autoApprovalEligible",
            "approvalReductionApplied",
            "summary",
            "rationale"
          ],
          "properties": {
            "routeClass": { "type": "string", "minLength": 1 },
            "overallScore": { "type": "number" },
            "evidenceCount": { "type": "integer" },
            "operatorAgreementRate": { "type": ["number", "null"] },
            "reviewClearRate": { "type": ["number", "null"] },
            "reversalCount": { "type": "integer" },
            "autoApprovalEligible": { "type": "boolean" },
            "approvalReductionApplied": { "type": "boolean" },
            "summary": { "type": "string", "minLength": 1 },
            "rationale": { "type": "array", "items": { "type": "string" } }
          }
        },
        "sourceMemory": {
          "type": ["object", "null"],
          "required": ["summary", "biasAdjustments", "matchingTopics", "matchingRouteClass", "rationale"],
          "properties": {
            "summary": { "type": "string", "minLength": 1 },
            "biasAdjustments": { "type": "object" },
            "matchingTopics": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["token", "recentCount", "totalCount", "dominantLaneId"],
                "properties": {
                  "token": { "type": "string", "minLength": 1 },
                  "recentCount": { "type": "integer" },
                  "totalCount": { "type": "integer" },
                  "dominantLaneId": { "type": "string", "minLength": 1 }
                }
              }
            },
            "matchingRouteClass": {
              "type": ["object", "null"],
              "required": ["routeClass", "laneId", "sourceType", "recentCount", "totalCount", "lastSeenAt"],
              "properties": {
                "routeClass": { "type": "string", "minLength": 1 },
                "laneId": { "type": "string", "minLength": 1 },
                "sourceType": { "type": "string", "minLength": 1 },
                "recentCount": { "type": "integer" },
                "totalCount": { "type": "integer" },
                "lastSeenAt": { "type": "string", "minLength": 1 }
              }
            },
            "rationale": { "type": "array", "items": { "type": "string" } }
          }
        },
        "sourceSimilarity": {
          "type": ["object", "null"],
          "required": ["summary", "relatedSources"],
          "properties": {
            "summary": { "type": "string", "minLength": 1 },
            "relatedSources": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["runId", "candidateId", "candidateName", "laneId", "decisionState", "receivedAt", "similarityScore", "sharedTokens", "summary"],
                "properties": {
                  "runId": { "type": "string", "minLength": 1 },
                  "candidateId": { "type": "string", "minLength": 1 },
                  "candidateName": { "type": "string", "minLength": 1 },
                  "laneId": { "type": "string", "minLength": 1 },
                  "decisionState": { "type": "string", "minLength": 1 },
                  "receivedAt": { "type": "string", "minLength": 1 },
                  "similarityScore": { "type": "number" },
                  "sharedTokens": { "type": "array", "items": { "type": "string" } },
                  "summary": { "type": "string", "minLength": 1 }
                }
              }
            }
          }
        },
        "narrativeContext": {
          "type": ["object", "null"],
          "required": ["summary", "primaryThread", "relatedThreads", "biasAdjustments", "demandSignals", "rationale"],
          "properties": {
            "summary": { "type": "string", "minLength": 1 },
            "primaryThread": {
              "type": ["object", "null"],
              "required": [
                "threadId",
                "name",
                "state",
                "summary",
                "sourceCount",
                "firstSeenAt",
                "lastSeenAt",
                "activeSpanDays",
                "currentSourceOverlap",
                "topTokens",
                "laneTendency",
                "gapCoverage",
                "followThrough",
                "demandSignals",
                "relatedRunIds"
              ],
              "properties": {
                "threadId": { "type": "string", "minLength": 1 },
                "name": { "type": "string", "minLength": 1 },
                "state": { "enum": ["nascent", "developing", "mature", "stalled", "completed"] },
                "summary": { "type": "string", "minLength": 1 },
                "sourceCount": { "type": "integer" },
                "firstSeenAt": { "type": "string", "minLength": 1 },
                "lastSeenAt": { "type": "string", "minLength": 1 },
                "activeSpanDays": { "type": "integer" },
                "currentSourceOverlap": { "type": "integer" },
                "topTokens": { "type": "array", "items": { "type": "string" } },
                "laneTendency": {
                  "type": "object",
                  "required": ["dominantLaneId", "dominancePercent", "laneCounts", "biasAdjustment"],
                  "properties": {
                    "dominantLaneId": { "type": "string", "minLength": 1 },
                    "dominancePercent": { "type": "number" },
                    "laneCounts": { "type": "object" },
                    "biasAdjustment": { "type": "number" }
                  }
                },
                "gapCoverage": {
                  "type": "object",
                  "required": ["dominantGapId", "matchedGapIds", "status"],
                  "properties": {
                    "dominantGapId": { "type": ["string", "null"] },
                    "matchedGapIds": { "type": "array", "items": { "type": "string" } },
                    "status": { "enum": ["none", "emerging", "partially_addressed", "closed"] }
                  }
                },
                "followThrough": {
                  "type": "object",
                  "required": ["completedProofCount", "stalledProofCount", "followThroughRate"],
                  "properties": {
                    "completedProofCount": { "type": "integer" },
                    "stalledProofCount": { "type": "integer" },
                    "followThroughRate": { "type": "number" }
                  }
                },
                "demandSignals": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["kind", "priority", "summary", "requestedLaneId"],
                    "properties": {
                      "kind": { "type": "string", "minLength": 1 },
                      "priority": { "enum": ["low", "medium", "high"] },
                      "summary": { "type": "string", "minLength": 1 },
                      "requestedLaneId": { "type": ["string", "null"] }
                    }
                  }
                },
                "relatedRunIds": { "type": "array", "items": { "type": "string" } }
              }
            },
            "relatedThreads": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "threadId",
                  "name",
                  "state",
                  "summary",
                  "sourceCount",
                  "firstSeenAt",
                  "lastSeenAt",
                  "activeSpanDays",
                  "currentSourceOverlap",
                  "topTokens",
                  "laneTendency",
                  "gapCoverage",
                  "followThrough",
                  "demandSignals",
                  "relatedRunIds"
                ],
                "properties": {
                  "threadId": { "type": "string", "minLength": 1 },
                  "name": { "type": "string", "minLength": 1 },
                  "state": { "enum": ["nascent", "developing", "mature", "stalled", "completed"] },
                  "summary": { "type": "string", "minLength": 1 },
                  "sourceCount": { "type": "integer" },
                  "firstSeenAt": { "type": "string", "minLength": 1 },
                  "lastSeenAt": { "type": "string", "minLength": 1 },
                  "activeSpanDays": { "type": "integer" },
                  "currentSourceOverlap": { "type": "integer" },
                  "topTokens": { "type": "array", "items": { "type": "string" } },
                  "laneTendency": {
                    "type": "object",
                    "required": ["dominantLaneId", "dominancePercent", "laneCounts", "biasAdjustment"],
                    "properties": {
                      "dominantLaneId": { "type": "string", "minLength": 1 },
                      "dominancePercent": { "type": "number" },
                      "laneCounts": { "type": "object" },
                      "biasAdjustment": { "type": "number" }
                    }
                  },
                  "gapCoverage": {
                    "type": "object",
                    "required": ["dominantGapId", "matchedGapIds", "status"],
                    "properties": {
                      "dominantGapId": { "type": ["string", "null"] },
                      "matchedGapIds": { "type": "array", "items": { "type": "string" } },
                      "status": { "enum": ["none", "emerging", "partially_addressed", "closed"] }
                    }
                  },
                  "followThrough": {
                    "type": "object",
                    "required": ["completedProofCount", "stalledProofCount", "followThroughRate"],
                    "properties": {
                      "completedProofCount": { "type": "integer" },
                      "stalledProofCount": { "type": "integer" },
                      "followThroughRate": { "type": "number" }
                    }
                  },
                  "demandSignals": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["kind", "priority", "summary", "requestedLaneId"],
                      "properties": {
                        "kind": { "type": "string", "minLength": 1 },
                        "priority": { "enum": ["low", "medium", "high"] },
                        "summary": { "type": "string", "minLength": 1 },
                        "requestedLaneId": { "type": ["string", "null"] }
                      }
                    }
                  },
                  "relatedRunIds": { "type": "array", "items": { "type": "string" } }
                }
              }
            },
            "biasAdjustments": { "type": "object" },
            "demandSignals": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["kind", "priority", "summary", "requestedLaneId"],
                "properties": {
                  "kind": { "type": "string", "minLength": 1 },
                  "priority": { "enum": ["low", "medium", "high"] },
                  "summary": { "type": "string", "minLength": 1 },
                  "requestedLaneId": { "type": ["string", "null"] }
                }
              }
            },
            "rationale": { "type": "array", "items": { "type": "string" } }
          }
        },
        "laneProportions": { "type": "object" },
        "secondaryLanes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["laneId", "proportion", "reason"],
            "properties": {
              "laneId": { "type": "string", "minLength": 1 },
              "proportion": { "type": "number" },
              "reason": { "type": "string", "minLength": 1 }
            }
          }
        },
        "scoreBreakdown": {
          "type": "object",
          "required": [
            "missionFit",
            "gapAlignment",
            "laneScores",
            "keywordLaneScores",
            "metadataLaneScores",
            "gapLaneScores",
            "metaUsefulnessSignal",
            "patternExtractionSignal",
            "transformationSignal",
            "runtimeSignal",
            "ambiguityPenalty",
            "total"
          ],
          "properties": {
            "missionFit": { "type": "number" },
            "gapAlignment": { "type": "number" },
            "laneScores": { "type": "object" },
            "keywordLaneScores": { "type": "object" },
            "metadataLaneScores": { "type": "object" },
            "gapLaneScores": { "type": "object" },
            "metaUsefulnessSignal": { "type": "number" },
            "patternExtractionSignal": { "type": "number" },
            "transformationSignal": { "type": "number" },
            "runtimeSignal": { "type": "number" },
            "ambiguityPenalty": { "type": "number" },
            "total": { "type": "number" }
          }
        },
        "explanationBreakdown": {
          "type": "object",
          "required": [
            "keywordSignals",
            "metadataSignals",
            "gapAlignmentSignals",
            "ambiguitySignals"
          ],
          "properties": {
            "keywordSignals": { "type": "array", "items": { "type": "string" } },
            "metadataSignals": { "type": "array", "items": { "type": "string" } },
            "gapAlignmentSignals": { "type": "array", "items": { "type": "string" } },
            "ambiguitySignals": { "type": "array", "items": { "type": "string" } }
          }
        },
        "rationale": { "type": "array", "items": { "type": "string" } }
      }
    },
    "extractionPlan": {
      "type": "object",
      "required": ["extractedValue", "excludedBaggage"],
      "properties": {
        "extractedValue": { "type": "array", "items": { "type": "string" } },
        "excludedBaggage": { "type": "array", "items": { "type": "string" } }
      }
    },
    "adaptationPlan": {
      "type": "object",
      "required": ["directiveOwnedForm", "adaptedValue"],
      "properties": {
        "directiveOwnedForm": { "type": "string", "minLength": 1 },
        "adaptedValue": { "type": "array", "items": { "type": "string" } }
      }
    },
    "improvementPlan": {
      "type": "object",
      "required": ["improvementGoals", "intendedDelta"],
      "properties": {
        "improvementGoals": { "type": "array", "items": { "type": "string" } },
        "intendedDelta": { "type": "string", "minLength": 1 }
      }
    },
    "proofPlan": {
      "type": "object",
      "required": ["proofKind", "objective", "requiredEvidence", "requiredGates", "rollbackPrompt"],
      "properties": {
        "proofKind": { "type": "string", "minLength": 1 },
        "objective": { "type": "string", "minLength": 1 },
        "requiredEvidence": { "type": "array", "items": { "type": "string" } },
        "requiredGates": { "type": "array", "items": { "type": "string" } },
        "rollbackPrompt": { "type": "string", "minLength": 1 }
      }
    },
    "decision": {
      "type": "object",
      "required": ["decisionState", "requiresHumanApproval", "summary", "rationale"],
      "properties": {
        "decisionState": {
          "enum": [
            "hold_in_discovery",
            "accept_for_architecture",
            "route_to_runtime_follow_up",
            "needs_human_review"
          ]
        },
        "requiresHumanApproval": { "type": "boolean" },
        "summary": { "type": "string", "minLength": 1 },
        "rationale": { "type": "array", "items": { "type": "string" } }
      }
    },
    "integrationProposal": {
      "type": "object",
      "required": [
        "targetLaneId",
        "integrationMode",
        "hostDependence",
        "valuableWithoutHostRuntime",
        "handoffArtifactFamily",
        "nextAction",
        "requiresHumanReview"
      ],
      "properties": {
        "targetLaneId": { "type": "string", "minLength": 1 },
        "integrationMode": { "type": "string", "minLength": 1 },
        "hostDependence": { "type": "string", "minLength": 1 },
        "valuableWithoutHostRuntime": { "type": "boolean" },
        "handoffArtifactFamily": { "type": "string", "minLength": 1 },
        "nextAction": { "type": "string", "minLength": 1 },
        "requiresHumanReview": { "type": "boolean" }
      }
    },
    "priorPlanContext": {
      "type": ["object", "null"],
      "required": [
        "routeClass",
        "summary",
        "matchingRunCount",
        "successfulFollowThroughCount",
        "stalledRunCount",
        "recurringImprovementGoals",
        "recurringProofKinds",
        "adaptationPatterns",
        "relatedRunIds"
      ],
      "properties": {
        "routeClass": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "matchingRunCount": { "type": "integer" },
        "successfulFollowThroughCount": { "type": "integer" },
        "stalledRunCount": { "type": "integer" },
        "recurringImprovementGoals": { "type": "array", "items": { "type": "string" } },
        "recurringProofKinds": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["proofKind", "count", "status"],
            "properties": {
              "proofKind": { "type": "string", "minLength": 1 },
              "count": { "type": "integer" },
              "status": { "enum": ["successful", "stalled", "mixed"] }
            }
          }
        },
        "adaptationPatterns": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["directiveOwnedForm", "count", "successfulCount", "stalledCount"],
            "properties": {
              "directiveOwnedForm": { "type": "string", "minLength": 1 },
              "count": { "type": "integer" },
              "successfulCount": { "type": "integer" },
              "stalledCount": { "type": "integer" }
            }
          }
        },
        "relatedRunIds": { "type": "array", "items": { "type": "string" } }
      }
    },
    "reportPlan": {
      "type": "object",
      "required": ["reportKind", "summary", "usefulnessRationale", "requiredDestinations", "syncRequired"],
      "properties": {
        "reportKind": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "usefulnessRationale": { "type": "string", "minLength": 1 },
        "requiredDestinations": { "type": "array", "items": { "type": "string" } },
        "syncRequired": { "type": "boolean" }
      }
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "at", "summary"],
        "properties": {
          "type": { "type": "string", "minLength": 1 },
          "at": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
