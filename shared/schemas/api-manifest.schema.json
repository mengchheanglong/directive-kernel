{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "shared/schemas/api-manifest.schema.json",
  "title": "API Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "operations",
    "capabilities",
    "schema_index"
  ],
  "properties": {
    "$schema": {
      "enum": [
        "shared/schemas/api-manifest.schema.json",
        "/api/schemas/api-manifest.schema.json"
      ]
    },
    "operations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/operationEntry"
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/capabilityEntry"
      }
    },
    "schema_index": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "operationEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "method",
        "path",
        "summary"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "method": {
          "enum": [
            "GET",
            "POST"
          ]
        },
        "path": {
          "type": "string",
          "pattern": "^/api/"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "profiles": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "MCP tool profiles this operation belongs to (e.g. [\"core\"]). Untagged operations are only in the \"full\" profile."
        },
        "input_schema": {
          "type": "string",
          "minLength": 1
        },
        "output_schema": {
          "type": "string",
          "minLength": 1
        },
        "side_effects": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "prerequisites": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "allowed_after": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          }
        }
      }
    },
    "capabilityEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "metadata": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "displayName": {
              "type": "string",
              "minLength": 1
            },
            "description": {
              "type": "string",
              "minLength": 1
            },
            "domain": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "inputSchema": {
          "type": "string",
          "minLength": 1
        },
        "outputSchema": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
