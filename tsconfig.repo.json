{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true
  },
  "include": [
    "index.ts",
    "engine/**/*.ts",
    "discovery/**/*.ts",
    "runtime/**/*.ts",
    "architecture/**/*.ts",
    "hosts/**/*.ts",
    "shared/**/*.ts",
    "scripts/**/*.ts"
  ],
  "exclude": [
    "ui/**",
    "node_modules/**",
    "local/**"
  ]
}
